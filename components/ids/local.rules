# Regola per intercettare l'attacco dell'insider-threat a prescindere dall'IP
alert tcp any any -> any any (msg:"ZTA ZERO TRUST ALERT: SQL Injection pattern origin detected!"; content:"OR 1=1"; sid:1000001; rev:1;)
alert tcp any any -> any 80 (msg:"ZTA ZERO TRUST ALERT: Admin Dump endpoint access attempted!"; content:"api/v1/admin/dump"; sid:1000002; rev:1;)
