# DA VERIFICARE (BASE PROVVISORIA)
# =======================================================
# ZTA 2026 - REGOLE SNORT PER ENVOY/MONGODB
# =======================================================

# 1. Rileva una scansione Nmap (SYN Scan) verso il nostro Envoy o DB
alert tcp any any -> any any (msg:"ZTA ALERT: Rilevata Scansione di Rete (Possibile Nmap)"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:1000001; rev:1;)

# 2. Rileva un tentativo di connessione diretta (bypass) alla porta di MongoDB
alert tcp any any -> any 27017 (msg:"ZTA ALERT: Tentativo di accesso diretto a MongoDB bypassando Envoy!"; sid:1000002; rev:1;)